# Path to the OKF bundle directory the agent manages
BUNDLE_ROOT=./sample-bundle

# ── Primary model ──────────────────────────────────────────────────────
# Any OpenAI-compatible or Anthropic-compatible API endpoint.
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_API_FORMAT=openai          # "openai" | "anthropic"
LLM_MODEL=                     # model id to request, e.g. "deepseek-chat" or "claude-sonnet-5"

# ── Fallback model (optional) ──────────────────────────────────────────
# Used when the primary model fails with a retryable error (timeout, 5xx).
# Leave LLM_FALLBACK_API_BASE_URL empty to disable fallback.
LLM_FALLBACK_API_BASE_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_API_FORMAT=openai
LLM_FALLBACK_MODEL=
# LLM_FALLBACK_ALLOW_FOR=query   # optional: restrict to read-only operations
# LLM_FALLBACK_RETRY_429=false   # optional: also fail over to the fallback on 429 (rate-limit) responses

# ── Legacy env vars (still work but deprecated) ─────────────────────────
# Prefer the LLM_API_* vars above. These are mapped automatically.
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# LLAMACPP_BASE_URL=
# LLAMACPP_API_KEY=
# LOCAL_BASE_URL=
# LOCAL_API_KEY=

# Commit bundle changes to git after each mutation
GIT_AUTOCOMMIT=false

# ── Agent tuning ───────────────────────────────────────────────────────
LLM_MAX_STEPS=12                # max tool-calling steps per agent run
LLM_MUTATION_TEMPERATURE=0.2    # sampling temperature for mutations (0 = deterministic)

# ── Thinking / reasoning ───────────────────────────────────────────────
# Enable model thinking per task mode. CSV of: query,mutate,chat,maintain — or "*" for all.
# Leave empty to disable. Example: LLM_THINKING=mutate,maintain
LLM_THINKING=
LLM_THINKING_BUDGET=8000        # anthropic-format thinking token budget
LLM_REASONING_EFFORT=           # openai-format reasoning_effort (e.g. "low"|"medium"|"high")
LLM_EXTRA_BODY=                 # extra JSON shallow-merged into openai-format request bodies, e.g. {"top_p":0.9}

# ── Prompt sizing ──────────────────────────────────────────────────────
UNDERSTORY_TREE_BUDGET=4000     # char budget for the bundle tree in the system prompt (degrades past this)

# ── Hybrid search: embeddings (vector tier) ────────────────────────────
# Set LLM_EMBEDDING_API_BASE_URL to enable semantic search (OpenAI-compatible
# /v1/embeddings, e.g. a llama-server --embedding instance). Left empty, search
# stays FTS/BM25-only. Vectors warm in the background; search degrades gracefully.
LLM_EMBEDDING_API_BASE_URL=     # e.g. http://host.docker.internal:8081
LLM_EMBEDDING_API_KEY=          # default "not-needed"
LLM_EMBEDDING_MODEL=            # model id; empty → discovered from /v1/models
LLM_EMBEDDING_DIMS=             # embedding dimensionality; empty → learned from first response

PORT=3800

# Optional: require "Authorization: Bearer <token>" on /mcp and /api.
# Unset = open (fine for localhost/LAN). Set this before exposing understory anywhere.
#AUTH_TOKEN=
